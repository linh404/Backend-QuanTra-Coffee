# Database (MySQL)
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://root:password@127.0.0.1:3306/quantra-caffee

# Auth
JWT_SECRET=change_me_jwt_secret
NEXTAUTH_SECRET=change_me_nextauth_secret
NEXTAUTH_URL=http://localhost:3000

# Environment
NODE_ENV=development

# Optional services used by existing backend routes
GEMINI_API_KEY=
ENCRYPTION_KEY=your-encryption-key-32-characters-here
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# VNPay (optional if using VNPay routes)
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payment/vnpay/return
VERCEL_URL=

# Cafe Information (Used by AI Chatbot)
CAFE_NAME="Tên quán của bạn"
CAFE_ADDRESS="Địa chỉ quán"
CAFE_HOURS="Giờ hoạt động"
CAFE_HOTLINE="Số điện thoại"
CAFE_WIFI="Thông tin wifi"
CAFE_DELIVERY_POLICY="Chính sách giao hàng"
CAFE_PAYMENT_METHODS="Các hình thức thanh toán"
CAFE_EVENTS_POLICY="Chính sách đặt tiệc, sự kiện"
